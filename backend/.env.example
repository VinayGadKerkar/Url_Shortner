# ─────────────────────────────────────────────────────────────────────────────
# URL Shortener — Environment Variables
# Copy this file to .env and fill in the values before running.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
# The publicly reachable base URL used when constructing short URL responses.
BASE_URL=http://localhost:8080
# Graceful shutdown timeout in seconds.
SHUTDOWN_TIMEOUT_SECONDS=30

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=urlshortener
DB_SSLMODE=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
# How long a URL stays in Redis cache before expiring (seconds). Default: 1 hour.
REDIS_CACHE_TTL_SECONDS=3600

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=url-clicks
